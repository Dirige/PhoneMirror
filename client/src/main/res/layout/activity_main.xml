<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1929"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="手机镜像"
            android:textSize="36sp"
            android:textColor="#00E5FF"
            android:textStyle="bold"
            android:layout_marginTop="48dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="车机端"
            android:textSize="14sp"
            android:textColor="#80CBC4"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未连接"
            android:textSize="16sp"
            android:textColor="#78909C"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_marginTop="32dp"
            android:background="#132F4C">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="连接设置"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_host"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:hint="手机IP地址"
                android:textColor="#E0E0E0"
                android:textColorHint="#78909C"
                android:background="#0D2137"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/et_port"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:hint="端口 (默认7201)"
                android:textColor="#E0E0E0"
                android:textColorHint="#78909C"
                android:background="#0D2137"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="number"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btn_scan"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="扫描局域网设备"
                android:textColor="#00E5FF"
                android:backgroundTint="#0D2137"
                android:textSize="15sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_devices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#80CBC4"
            android:textSize="13sp"
            android:lineSpacingExtra="4dp" />

        <Button
            android:id="@+id/btn_connect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="连接投屏"
            android:textColor="#003544"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#00E5FF" />

    </LinearLayout>
</ScrollView>
